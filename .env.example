# ─────────────────────────────────────────────────────
# OpenRouter API (get from https://openrouter.ai)
# Used for: Whisper transcription + LLM summarization
# ─────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─────────────────────────────────────────────────────
# Google OAuth (get from https://console.cloud.google.com)
# Used for: Login with Google
# ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# ─────────────────────────────────────────────────────
# Session Secret (any random long string)
# Used for: Keeping user logged in
# ─────────────────────────────────────────────────────
SESSION_SECRET=make_this_a_long_random_string_here

# ─────────────────────────────────────────────────────
# App Config
# ─────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# ─────────────────────────────────────────────────────
# Tier Config (admin control)
# Set user tier manually for now: free | pro | max
# 💳 PAYMENT_HOOK — connect Stripe/Razorpay here in future
# ─────────────────────────────────────────────────────
DEFAULT_USER_TIER=free